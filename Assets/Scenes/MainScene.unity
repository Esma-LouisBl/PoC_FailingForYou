  m_Script: {fileID: 11500000, guid: c207cbb0e5d9e9e469a657490459cbc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MG_QuestionManager
  gameManager: {fileID: 1787514859}
  questionTMP: {fileID: 7561791677854465757}
  aspectTMP: {fileID: 582124521268859364}
  winnerTMP: {fileID: 338091246326603746}
  answer1TMP: {fileID: 328285602744811115}
  answer2TMP: {fileID: 268184581798757903}
  answer3TMP: {fileID: 2958838124939458765}
  answer4TMP: {fileID: 1212738180492576234}
  answerToIlluminate: {fileID: 0}
  chara1: {fileID: 0}
  chara2: {fileID: 0}
  chara3: {fileID: 0}
  chara4: {fileID: 0}
  questionsList:
  - "Vous \xEAtes allong\xE9 sur la plage et un enfant vous jette du sable dessus,
    que lui dites-vous ?"
  - Vous nagez dans la mer et voyez un requin sapprocher de vous, que faites-vous
    ?
  - "Un enfant vient de finir son ch\xE2teau de sable mais un chien fonce droit dessus.
    Quelle est votre r\xE9action ?"
  - "Vous vous appr\xEAtiez \xE0 partir de la plage mais le moteur de votre voiture
    vient de l\xE2cher. Comment allez-vous faire pour rentrer ?"
  - "Une vieille dame s'est fait enterr\xE9 dans le sable jusqu'au cou par un enfant.
    Que faites vous ?"
  - "Un crabe a vol\xE9 une glace au marchand, que faites vous ?"
  aspectsList:
  - Bienveillante
  - Rebelle
  - "D\xE9bile"
  - Soutenue
